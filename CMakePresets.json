{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 0
    },
    "include": [
        "build/Release/generators/CMakePresets.json"
    ],
    "configurePresets": [
        {
            "name": "dev",
            "displayName": "Developer mode",
            "description": "Release build with tests, linting, formatting, and LSP compile commands",
            "inherits": "conan-release",
            "binaryDir": "${sourceDir}/build/Dev",
            "toolchainFile": "${sourceDir}/build/Release/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "BUILD_TESTING": true,
                "DICOM_EDITOR_DEVELOPER_MODE": true,
                "DICOM_EDITOR_ENABLE_LSP": true,
                "DICOM_EDITOR_ENABLE_STRICT_WARNINGS": true
            }
        },
        {
            "name": "iwyu",
            "displayName": "Include-what-you-use",
            "description": "Developer build with native CMake include-what-you-use integration",
            "inherits": "dev",
            "binaryDir": "${sourceDir}/build/IWYU",
            "cacheVariables": {
                "DICOM_EDITOR_ENABLE_IWYU": true
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "format",
            "configurePreset": "dev",
            "targets": [
                "format"
            ]
        },
        {
            "name": "check-format",
            "configurePreset": "dev",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "lint",
            "configurePreset": "dev",
            "targets": [
                "lint"
            ]
        },
        {
            "name": "cppcheck",
            "configurePreset": "dev",
            "targets": [
                "cppcheck"
            ]
        },
        {
            "name": "iwyu",
            "configurePreset": "iwyu",
            "cleanFirst": true
        },
        {
            "name": "check-format-iwyu",
            "configurePreset": "iwyu",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "lint-iwyu",
            "configurePreset": "iwyu",
            "targets": [
                "lint"
            ]
        },
        {
            "name": "cppcheck-iwyu",
            "configurePreset": "iwyu",
            "targets": [
                "cppcheck"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "iwyu",
            "configurePreset": "iwyu",
            "output": {
                "outputOnFailure": true
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "dev-check",
            "displayName": "Developer verification",
            "description": "Configure, build, check formatting, lint, and test",
            "steps": [
                {
                    "type": "configure",
                    "name": "dev"
                },
                {
                    "type": "build",
                    "name": "dev"
                },
                {
                    "type": "build",
                    "name": "check-format"
                },
                {
                    "type": "build",
                    "name": "lint"
                },
                {
                    "type": "build",
                    "name": "cppcheck"
                },
                {
                    "type": "test",
                    "name": "dev"
                }
            ]
        },
        {
            "name": "all-checks",
            "displayName": "Developer verification with IWYU",
            "description": "Run developer verification and a clean include-what-you-use build",
            "steps": [
                {
                    "type": "configure",
                    "name": "iwyu"
                },
                {
                    "type": "build",
                    "name": "iwyu"
                },
                {
                    "type": "build",
                    "name": "check-format-iwyu"
                },
                {
                    "type": "build",
                    "name": "lint-iwyu"
                },
                {
                    "type": "build",
                    "name": "cppcheck-iwyu"
                },
                {
                    "type": "test",
                    "name": "iwyu"
                }
            ]
        }
    ]
}
