{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "conan-debug-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/Debug",
            "toolchainFile": "${sourceDir}/build/Debug/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "BUILD_TESTING": true,
                "CMAKE_BUILD_TYPE": "Debug",
                "DICOM_EDITOR_DCMTK_DICT_FILE": "${sourceDir}/build/Debug/generators/dicom.dic"
            }
        },
        {
            "name": "conan-release-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/Release",
            "toolchainFile": "${sourceDir}/build/Release/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "BUILD_TESTING": false,
                "CMAKE_BUILD_TYPE": "Release",
                "DICOM_EDITOR_DEVELOPER_MODE": false,
                "DICOM_EDITOR_DCMTK_DICT_FILE": "${sourceDir}/build/Release/generators/dicom.dic"
            }
        },
        {
            "name": "conan-ninja-debug-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Ninja-Debug",
            "toolchainFile": "${sourceDir}/build/Ninja-Debug/generators/conan_toolchain.cmake",
            "cacheVariables": {
                "BUILD_TESTING": true,
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_SCAN_FOR_MODULES": false,
                "DICOM_EDITOR_DCMTK_DICT_FILE": "${sourceDir}/build/Ninja-Debug/generators/dicom.dic"
            }
        },
        {
            "name": "dev",
            "displayName": "Daily development",
            "description": "Debug build with tests, strict warnings, and formatting",
            "inherits": "conan-debug-base",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": false,
                "DICOM_EDITOR_DEVELOPER_MODE": true
            }
        },
        {
            "name": "dev-ninja",
            "displayName": "Daily development with Ninja",
            "description": "Debug development build with a compilation database on every platform",
            "inherits": "conan-ninja-debug-base",
            "cacheVariables": {
                "DICOM_EDITOR_DEVELOPER_MODE": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            }
        },
        {
            "name": "production",
            "displayName": "Production executable",
            "description": "Optimized Release build used for the final executable",
            "inherits": "conan-release-base"
        },
        {
            "name": "quality",
            "displayName": "Extended quality checks",
            "description": "Ninja Debug build with clang-tidy and cppcheck targets",
            "inherits": "dev-ninja",
            "binaryDir": "${sourceDir}/build/Ninja-Debug-Quality",
            "cacheVariables": {
                "DICOM_EDITOR_ENABLE_CLANG_TIDY": true,
                "DICOM_EDITOR_ENABLE_CPPCHECK": true
            }
        },
        {
            "name": "iwyu",
            "displayName": "All checks with IWYU",
            "description": "Extended quality build with include-what-you-use enabled",
            "inherits": "quality",
            "binaryDir": "${sourceDir}/build/Ninja-Debug-IWYU",
            "cacheVariables": {
                "DICOM_EDITOR_ENABLE_IWYU": true
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "configuration": "Debug"
        },
        {
            "name": "production",
            "configurePreset": "production",
            "configuration": "Release"
        },
        {
            "name": "dev-ninja",
            "configurePreset": "dev-ninja",
            "configuration": "Debug"
        },
        {
            "name": "format",
            "configurePreset": "dev",
            "configuration": "Debug",
            "targets": [
                "format"
            ]
        },
        {
            "name": "check-format",
            "configurePreset": "dev",
            "configuration": "Debug",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "format-ninja",
            "configurePreset": "dev-ninja",
            "configuration": "Debug",
            "targets": [
                "format"
            ]
        },
        {
            "name": "check-format-ninja",
            "configurePreset": "dev-ninja",
            "configuration": "Debug",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "quality",
            "configurePreset": "quality",
            "configuration": "Debug"
        },
        {
            "name": "check-format-quality",
            "configurePreset": "quality",
            "configuration": "Debug",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "lint",
            "configurePreset": "quality",
            "configuration": "Debug",
            "targets": [
                "lint"
            ]
        },
        {
            "name": "cppcheck",
            "configurePreset": "quality",
            "configuration": "Debug",
            "targets": [
                "cppcheck"
            ]
        },
        {
            "name": "iwyu",
            "configurePreset": "iwyu",
            "configuration": "Debug",
            "cleanFirst": true
        },
        {
            "name": "check-format-iwyu",
            "configurePreset": "iwyu",
            "configuration": "Debug",
            "targets": [
                "check-format"
            ]
        },
        {
            "name": "lint-iwyu",
            "configurePreset": "iwyu",
            "configuration": "Debug",
            "targets": [
                "lint"
            ]
        },
        {
            "name": "cppcheck-iwyu",
            "configurePreset": "iwyu",
            "configuration": "Debug",
            "targets": [
                "cppcheck"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "dev-ninja",
            "configurePreset": "dev-ninja",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "quality",
            "configurePreset": "quality",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "iwyu",
            "configurePreset": "iwyu",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "dev-check",
            "displayName": "Daily developer verification",
            "description": "Configure and build Debug, check formatting, and run tests",
            "steps": [
                {
                    "type": "configure",
                    "name": "dev"
                },
                {
                    "type": "build",
                    "name": "dev"
                },
                {
                    "type": "build",
                    "name": "check-format"
                },
                {
                    "type": "test",
                    "name": "dev"
                }
            ]
        },
        {
            "name": "quality-checks",
            "displayName": "Extended quality verification",
            "description": "Run Debug build, formatting, clang-tidy, cppcheck, and tests",
            "steps": [
                {
                    "type": "configure",
                    "name": "quality"
                },
                {
                    "type": "build",
                    "name": "quality"
                },
                {
                    "type": "build",
                    "name": "check-format-quality"
                },
                {
                    "type": "build",
                    "name": "lint"
                },
                {
                    "type": "build",
                    "name": "cppcheck"
                },
                {
                    "type": "test",
                    "name": "quality"
                }
            ]
        },
        {
            "name": "dev-check-ninja",
            "displayName": "Daily developer verification with Ninja",
            "description": "Run the daily Debug workflow with a compilation database",
            "steps": [
                {
                    "type": "configure",
                    "name": "dev-ninja"
                },
                {
                    "type": "build",
                    "name": "dev-ninja"
                },
                {
                    "type": "build",
                    "name": "check-format-ninja"
                },
                {
                    "type": "test",
                    "name": "dev-ninja"
                }
            ]
        },
        {
            "name": "all-checks",
            "displayName": "Full verification with IWYU",
            "description": "Run a clean IWYU build plus every extended quality check",
            "steps": [
                {
                    "type": "configure",
                    "name": "iwyu"
                },
                {
                    "type": "build",
                    "name": "iwyu"
                },
                {
                    "type": "build",
                    "name": "check-format-iwyu"
                },
                {
                    "type": "build",
                    "name": "lint-iwyu"
                },
                {
                    "type": "build",
                    "name": "cppcheck-iwyu"
                },
                {
                    "type": "test",
                    "name": "iwyu"
                }
            ]
        }
    ]
}
